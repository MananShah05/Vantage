# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real env files but keep example templates tracked
.env
.env.*
*.env
**/.env
**/.env.*
secrets/
*secrets*
!.env.example
!**/.env.example
!*.env.example

# Markdown files and folders
*.md
**/*.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
