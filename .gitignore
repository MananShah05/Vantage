# Secrets / env — ignore all real env files anywhere…
.env
.env.*
*.env
**/.env
**/.env.*
secrets/
*secrets*
*.pem
*.key
*.p12
*.pfx

# …but always keep the example/template files in the repo
!.env.example
!**/.env.example
!*.env.example

# Markdown files and folders
*.md
**/*.md
docs/

# Node / Next
node_modules/
.next/
out/
dist/
*.log
npm-debug.log*

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Build / coverage
coverage/
.cache/
.vercel
